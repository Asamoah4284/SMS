# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local Docker/Postgres (default dev)
DATABASE_URL="postgresql://sms_user:sms_password@localhost:5432/sms_db"

# Remote Neon example (optional)
# DATABASE_URL="postgresql://<user>:<password>@<your-neon-pooler-host>:5432/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_minimum_32_characters

# Public app URL (invite links, SMS) — use one origin only
FRONTEND_URL=http://localhost:3000

# CORS: comma-separated origins (plus any https://*.netlify.app is always allowed).
# CORS_ORIGINS=http://localhost:3000,https://sms-edutrack.netlify.app

# ─── School Identity (edit per deployment) ───────────────────────────────────
SCHOOL_NAME="My School"
SCHOOL_ABBREVIATION="MYSCH"
SCHOOL_MOTTO="Knowledge is Power"
SCHOOL_ADDRESS="123 School St, Accra"
SCHOOL_REGION="Greater Accra"
SCHOOL_DISTRICT="Accra Metro"
SCHOOL_PHONE="0200000000"
SCHOOL_EMAIL="info@myschool.edu.gh"
SCHOOL_LOGO="/logo.png"

# ─── SMS (Moolre) ─────────────────────────────────────────────────────────────
# https://moolre.com — get API key from dashboard
MOOLRE_API_KEY=your_moolre_api_key_here
MOOLRE_SENDER_ID="EduTrack"

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
