# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local Docker/Postgres (default dev)
DATABASE_URL="postgresql://sms_user:sms_password@localhost:5432/sms_db"

# Optional: raise Prisma pool if you see P2024 (connection pool timeout) under load / remote DB
# DATABASE_CONNECTION_LIMIT=15
# DATABASE_POOL_TIMEOUT=20

# Remote Neon example (optional)
# DATABASE_URL="postgresql://<user>:<password>@<your-neon-pooler-host>:5432/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_minimum_32_characters

# Frontend URL (SMS invite links, and CORS when CORS_ORIGINS is unset)
FRONTEND_URL=http://localhost:3000

# Optional: exact CORS allowlist (comma-separated). If set, replaces auto list (localhost + FRONTEND_URL).
# CORS_ORIGINS=http://localhost:3000,https://your-app.netlify.app

# ─── School Identity (edit per deployment) ───────────────────────────────────
SCHOOL_NAME="My School"
SCHOOL_ABBREVIATION="MYSCH"
SCHOOL_MOTTO="Knowledge is Power"
SCHOOL_ADDRESS="123 School St, Accra"
SCHOOL_REGION="Greater Accra"
SCHOOL_DISTRICT="Accra Metro"
SCHOOL_PHONE="0200000000"
SCHOOL_EMAIL="info@myschool.edu.gh"

# ─── SMS Gateway ──────────────────────────────────────────────────────────────
# Provider: "hubtel" or "arkesel"
SMS_PROVIDER=hubtel

# Hubtel
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_SENDER_ID=EduTrack

# Arkesel (alternative)
# ARKESEL_API_KEY=your_arkesel_api_key
# ARKESEL_SENDER_ID=EduTrack

# ─── Paystack (parent app “Pay with Paystack” on Fees) ───────────────────────
# Dashboard: https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Test: sk_test_...  |  Live: sk_live_...
# Webhook URL (production, HTTPS): https://<your-api-host>/api/v1/webhooks/paystack
PAYSTACK_SECRET_KEY=

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
